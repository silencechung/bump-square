---
import AppShell from '~src/components/AppShell.vue';
import { getLocale } from '~src/lib/serverState';

// Read the persisted locale server-side so the SSR'd shell matches the
// hydrated locale — without this, EN users would see a 100ms flash of
// zh-TW before Pinia + SSE picked up the truth.
const locale = getLocale();
---
<html lang={locale === 'zh-TW' ? 'zh-Hant' : 'en'}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>bump-square</title>
    <!-- UnoCSS (presetWind3) injects the stylesheet + preflight reset via the
         astro integration. Global resets and the button/scrollbar rules live in
         uno.config.ts's preflights. -->

  </head>
  <body class="bg-zinc-950">
    <AppShell client:load initialLocale={locale} />
  </body>
</html>
